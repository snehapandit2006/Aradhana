# ── AstroAgent Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to git.

# Groq API (free tier — get key at https://console.groq.com)
# Used for: LLM inference (Llama 3 70B) across all agent nodes
GROQ_API_KEY=your_groq_api_key_here

# Google Cloud APIs (free tier — get key at https://console.cloud.google.com)
# Enable: Geocoding API + Timezone API on the same key
# Used for: geocode_place() tool — resolving birth city to lat/lon/timezone
GOOGLE_GEOCODING_API_KEY=your_google_api_key_here

# Cohere API (free tier — get key at https://dashboard.cohere.com)
# Used for: embedding astrology knowledge chunks into Chroma (seed.py)
#           and embedding user queries at runtime (retriever.py)
# Free limit: 1,000 embed calls/month — seed.py checks IDs to avoid re-embedding
COHERE_API_KEY=your_cohere_api_key_here

# Frontend origin for CORS whitelist
# Development default — change to your deployed frontend URL in production
ALLOWED_ORIGIN=http://localhost:5173

# SQLite database path (relative to backend/)
DATABASE_URL=./astroagent.db
